# サーバー設定
PORT=3000

# PostgreSQL接続設定 (docker-compose の db サービスをそのまま使う場合の既定値)
# ホスト側は5433番で公開している(5432番は他のPostgresと衝突しやすいため)。コンテナ間通信では内部的に5432番を使う
DB_HOST=localhost
DB_PORT=5433
DB_USER=paper_order
DB_PASSWORD=paper_order_password
DB_NAME=paper_order

# 管理画面ログイン用のユーザーID・パスワード(注文一覧の閲覧・検索・ステータス変更・支払いリンク送信に使用)
ADMIN_USER_ID=admin
ADMIN_PASSWORD=change-me-to-a-random-string

# 管理者への注文通知メール送信先
ADMIN_NOTIFY_EMAIL=admin-mail@example.com

# メール送信設定 (開発時はGmail等のSMTP、本番はAWS SESのSMTP認証情報をそのまま設定すればOK)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="紙製品ショップ <no-reply@example.com>"

# アップロードファイルの保存先 (本番はS3等に差し替え予定。今はローカルディスク)
UPLOAD_DIR=./uploads

# フロントエンドのURL (CORS許可用)
FRONTEND_ORIGIN=http://localhost:5173
