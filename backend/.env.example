# サーバー設定
PORT=3000

# PostgreSQL接続設定 (docker-compose の db サービスをそのまま使う場合の既定値)
# ホスト側は5433番で公開している(5432番は他のPostgresと衝突しやすいため)。コンテナ間通信では内部的に5432番を使う
DB_HOST=localhost
DB_PORT=5433
DB_USER=root
DB_PASSWORD=password
DB_NAME=haguruma-store-portal

# 管理画面ログイン用のユーザーID・パスワード(注文一覧の閲覧・検索・ステータス変更・支払いリンク送信に使用)
ADMIN_USER_ID=admin
ADMIN_PASSWORD=password

# 管理者への注文通知メール送信先
ADMIN_NOTIFY_EMAIL=gakugaku0221@gmail.com

# メール送信設定
# Gmail: smtp.gmail.com / 587 / SMTP_SECURE=false / SMTP_REQUIRE_TLS=true / アプリパスワードを使用
# Mailpit: mailpit / 1025 / SMTP_SECURE=false / SMTP_REQUIRE_TLS=false / 認証情報は空
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=gakugaku0221@gmail.com
SMTP_PASS=
MAIL_FROM="HAGURUMA STORE PORTAL <gakugaku0221@gmail.com>"
MAIL_REPLY_TO=gakugaku0221@gmail.com

# アップロードファイルの保存先 (本番はS3等に差し替え予定。今はローカルディスク)
UPLOAD_DIR=./uploads

# フロントエンドのURL (CORS許可用)
FRONTEND_ORIGIN=http://localhost:5173

# AI注文分析 (OpenAI API。ChatGPT Plusとは別にAPIキーとAPI利用料金が必要)
# 未設定の場合もサーバーは起動するが、注文分析APIは503を返す
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
